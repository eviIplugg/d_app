rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- USERS ----------
    // Читать может любой авторизованный (лента, профили). Писать — только свой документ или админ.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update, delete: if request.auth != null && (
        request.auth.uid == userId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin'
      );
    }

    // ---------- SWIPES ----------
    // Читать — только свои свайпы или где ты цель. Создавать — только от своего имени.
    match /swipes/{swipeId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        resource.data.targetUserId == request.auth.uid
      );
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // ---------- MATCHES ----------
    // Читать/писать только если ты участник пары (userId1 или userId2).
    match /matches/{matchId} {
      allow read, update, delete: if request.auth != null && (
        resource.data.userId1 == request.auth.uid ||
        resource.data.userId2 == request.auth.uid
      );
      allow create: if request.auth != null && (
        request.resource.data.userId1 == request.auth.uid ||
        request.resource.data.userId2 == request.auth.uid
      );
    }

    // ---------- CHATS ----------
    // chatId = matchId. Документ чата может не существовать до первого сообщения — разрешаем по участникам мэтча.
    match /chats/{chatId} {
      allow read: if request.auth != null && (
        get(/databases/$(database)/documents/matches/$(chatId)).data.userId1 == request.auth.uid ||
        get(/databases/$(database)/documents/matches/$(chatId)).data.userId2 == request.auth.uid
      );
      allow create: if request.auth != null && (
        request.auth.uid in request.resource.data.get('participantIds', [])
      );
      allow update, delete: if request.auth != null && (
        request.auth.uid in resource.data.get('participantIds', [])
      );
    }
    match /chats/{chatId}/messages/{messageId} {
      allow read, write: if request.auth != null && (
        get(/databases/$(database)/documents/matches/$(chatId)).data.userId1 == request.auth.uid ||
        get(/databases/$(database)/documents/matches/$(chatId)).data.userId2 == request.auth.uid
      );
    }

    // ---------- POSTS ----------
    // Читать — все авторизованные. Создавать — только автор. Обновлять/удалять — автор или админ (модерация).
    match /posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if request.auth != null && (
        resource.data.authorId == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin'
      );
    }

    // ---------- EVENTS ----------
    // Читать все авторизованные. Создавать/обновлять/удалять — авторизованные (организатор проверяется в приложении).
    match /events/{eventId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null;
    }

    // ---------- VENUES ----------
    match /venues/{venueId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null;
    }

    // ---------- ПОДПИСКИ НА ОРГАНИЗАТОРОВ ----------
    // Документ: {userId}_{venueId}. Читать/писать только свой.
    match /eventSubscriptions/{docId} {
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // ---------- УЧАСТНИКИ МЕРОПРИЯТИЙ ----------
    match /eventParticipants/{docId} {
      allow read, write: if request.auth != null;
    }

    // ---------- ACTIVITIES (лента активности: лайки, матчи, просмотры) ----------
    match /activities/{activityId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && (
        request.resource.data.userId == request.auth.uid ||
        request.resource.data.actorId == request.auth.uid
      );
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // ---------- VERIFICATION (заявки на верификацию) ----------
    // documentId = userId. Читать/писать только свой документ; админ может обновлять любой (review).
    match /verification/{userId} {
      allow read, write: if request.auth != null && (
        request.auth.uid == userId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin'
      );
      allow create: if request.auth != null && request.auth.uid == userId;
    }

    // ---------- Кэш ленты (если используется) ----------
    match /feed/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Всё остальное — запрещено.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
