rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // users: читать может любой авторизованный (лента), писать — только свой документ.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    // swipes: создавать — только от своего имени; читать — свои свайпы или где ты цель (для проверки мэтча).
    match /swipes/{swipeId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        resource.data.targetUserId == request.auth.uid
      );
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }
    // matches: читать/писать если пользователь — участник пары.
    match /matches/{matchId} {
      allow read, write: if request.auth != null;
    }
    // chats: документ чата и субколлекция messages — для участников переписки.
    match /chats/{chatId} {
      allow read, write: if request.auth != null;
    }
    match /chats/{chatId}/messages/{messageId} {
      allow read, write: if request.auth != null;
    }
    // posts: читать все авторизованные, создавать/обновлять — автор.
    match /posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.authorId == request.auth.uid;
    }
    // events: читать все, создавать/обновлять — авторизованные (админ/организатор позже можно ограничить).
    match /events/{eventId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null;
    }
    match /venues/{venueId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null;
    }
    match /eventSubscriptions/{docId} {
      allow read, write: if request.auth != null;
    }
    match /eventParticipants/{docId} {
      allow read, write: if request.auth != null;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
