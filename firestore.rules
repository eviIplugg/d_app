rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin';
    }

    // ---------- USERS ----------
    // Читать может любой авторизованный (лента, профили). Писать — только свой документ или админ.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update, delete: if request.auth != null && (request.auth.uid == userId || isAdmin());

      match /likeNotifications/{notifId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null && request.resource.data.actorId == request.auth.uid;
        allow update, delete: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ---------- SWIPES ----------
    // Читать — только свои свайпы или где ты цель. Создавать — только от своего имени.
    match /swipes/{swipeId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        resource.data.targetUserId == request.auth.uid
      );
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // ---------- MATCHES ----------
    // Читать/писать только если ты участник пары (userId1 или userId2).
    match /matches/{matchId} {
      allow read, update, delete: if request.auth != null && (
        resource.data.userId1 == request.auth.uid ||
        resource.data.userId2 == request.auth.uid
      );
      allow create: if request.auth != null && (
        request.resource.data.userId1 == request.auth.uid ||
        request.resource.data.userId2 == request.auth.uid
      );
    }

    // ---------- CHATS ----------
    // chatId = matchId. Читать — участники мэтча или админ (для админки). Писать — только участники.
    match /chats/{chatId} {
      allow read: if request.auth != null && (
        get(/databases/$(database)/documents/matches/$(chatId)).data.userId1 == request.auth.uid ||
        get(/databases/$(database)/documents/matches/$(chatId)).data.userId2 == request.auth.uid ||
        isAdmin()
      );
      allow create: if request.auth != null && (
        request.auth.uid in request.resource.data.get('participantIds', [])
      );
      allow update, delete: if request.auth != null && (
        request.auth.uid in resource.data.get('participantIds', [])
      );
    }
    match /chats/{chatId}/messages/{messageId} {
      allow read, write: if request.auth != null && (
        get(/databases/$(database)/documents/matches/$(chatId)).data.userId1 == request.auth.uid ||
        get(/databases/$(database)/documents/matches/$(chatId)).data.userId2 == request.auth.uid ||
        isAdmin()
      );
    }

    // ---------- POSTS ----------
    // Читать — все авторизованные. Создавать — только автор. Обновлять/удалять — автор или админ (модерация).
    match /posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.authorId == request.auth.uid;
      // Автор/админ могут менять пост полностью.
      // Любой авторизованный пользователь может менять только лайки (likeCount, likedBy).
      allow update: if request.auth != null && (
        resource.data.authorId == request.auth.uid ||
        isAdmin() ||
        request.resource.data.diff(resource.data).changedKeys().hasOnly(['likeCount', 'likedBy'])
      );
      allow delete: if request.auth != null && (resource.data.authorId == request.auth.uid || isAdmin());

      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && request.resource.data.authorId == request.auth.uid;
        allow update: if request.auth != null && (
          resource.data.authorId == request.auth.uid ||
          request.resource.data.diff(resource.data).changedKeys().hasOnly(['likeCount', 'likedBy'])
        );
        allow delete: if request.auth != null && resource.data.authorId == request.auth.uid;
      }
    }

    match /postReports/{reportId} {
      allow read: if request.auth != null && resource.data.reporterId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.reporterId == request.auth.uid;
      allow update, delete: if false;
    }

    // ---------- STORIES (24 часа) ----------
    // История видна только автору, администратору и пользователям из поля visibleTo.
    match /stories/{storyId} {
      allow read: if request.auth != null && (
        resource.data.authorId == request.auth.uid ||
        request.auth.uid in resource.data.get('visibleTo', []) ||
        isAdmin()
      );
      allow create: if request.auth != null &&
        request.resource.data.authorId == request.auth.uid &&
        request.auth.uid in request.resource.data.get('visibleTo', []);
      allow update, delete: if request.auth != null && (
        resource.data.authorId == request.auth.uid ||
        isAdmin()
      );
    }

    // ---------- EVENTS ----------
    // Читать все авторизованные. Создавать/обновлять/удалять — только создатель (organizer) или админ.
    match /events/{eventId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.get('createdBy', request.auth.uid) == request.auth.uid;
      allow update, delete: if request.auth != null && (
        resource.data.get('createdBy', '') == request.auth.uid || isAdmin()
      );
    }

    // ---------- VENUES ----------
    match /venues/{venueId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.get('ownerId', request.auth.uid) == request.auth.uid;
      allow update, delete: if request.auth != null && (
        resource.data.get('ownerId', '') == request.auth.uid || isAdmin()
      );
    }

    // ---------- ПОДПИСКИ НА ОРГАНИЗАТОРОВ ----------
    // Документ: {userId}_{venueId}. Читать/писать только свой.
    match /eventSubscriptions/{docId} {
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // ---------- УЧАСТНИКИ МЕРОПРИЯТИЙ ----------
    match /eventParticipants/{docId} {
      allow read, write: if request.auth != null;
    }

    // ---------- ACTIVITIES (лента активности: лайки, матчи, просмотры) ----------
    match /activities/{activityId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && (
        request.resource.data.userId == request.auth.uid ||
        request.resource.data.actorId == request.auth.uid
      );
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // ---------- VERIFICATION (заявки на верификацию) ----------
    // documentId = userId. Читать/писать только свой документ; админ может обновлять любой (review).
    match /verification/{userId} {
      allow read, write: if request.auth != null && (
        request.auth.uid == userId ||
        isAdmin()
      );
      allow create: if request.auth != null && request.auth.uid == userId;
    }

    // ---------- BLACKLIST ----------
    // Читать/писать может только админ. Клиент проверяет только по `exists` через Cloud Functions или по read rule
    // (для простоты даём read только админам).
    match /blacklist/{docId} {
      allow read, write: if isAdmin();
    }

    // ---------- Кэш ленты (если используется) ----------
    match /feed/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Всё остальное — запрещено.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
